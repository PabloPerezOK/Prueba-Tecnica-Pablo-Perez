# URL base de Ollama (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo para embeddings (debe estar descargado en Ollama)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Modelo para generación de respuestas
OLLAMA_CHAT_MODEL=llama3.2

# Cantidad de fragmentos a recuperar por consulta
TOP_K_CHUNKS=7

# Distancia coseno máxima para incluir un fragmento (0 = idéntico, 1 = opuesto)
# Valores menores = más estricto. Rango recomendado: 0.70 – 0.85
MAX_DISTANCE=0.78

# Timeout para llamadas a Ollama o OpenAI (segundos)
REQUEST_TIMEOUT_SECONDS=60

# Clave para proteger el endpoint /ask de la API Python
API_KEY=cambia-esta-clave-en-produccion

# --- Configuración OpenAI (opcional) ---
# Poner USE_OPENAI=true para usar OpenAI en lugar de Ollama
USE_OPENAI=false
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
